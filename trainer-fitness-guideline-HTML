<title>CHART カラダづくり診断</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Noto+Sans+JP:wght@400;500;700&family=M+PLUS+Rounded+1c:wght@500;700;800&display=swap');
:root {
  --navy: #1F9C8C;      /* メイン(フレッシュティール) */
  --gold: #FF8A5C;      /* アクセント(コーラルオレンジ) */
  --goldsoft: #FFE8DC;  /* アクセント淡(ピーチ) */
  --paper: #FFF9F2;     /* 背景(あたたかいクリーム) */
  --ink: #3D3A37;
  --inksoft: #8A857E;
  --line: #F0E0D2;
  --alert: #E8654F;
}
* { box-sizing: border-box; }
body { margin: 0; background: var(--paper); color: var(--ink); font-family: 'Noto Sans JP', sans-serif; -webkit-font-smoothing: antialiased; }
button { font: inherit; cursor: pointer; background: none; border: none; padding: 0; color: inherit; }
.wrap { max-width: 32rem; margin: 0 auto; padding: 40px 24px; }
.header { text-align: center; margin-bottom: 40px; }
.eyebrow { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 11px; letter-spacing: 0.25em; color: var(--gold); }
.title { font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 26px; color: var(--navy); letter-spacing: 0.04em; margin: 8px 0 0; }
.text-center { text-align: center; }
.intro-p { font-size: 14px; color: var(--inksoft); line-height: 1.75; margin: 0 0 32px; }
.btn-primary { background: var(--navy); color: var(--gold); font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700; font-size: 14px; letter-spacing: 0.05em; padding: 12px 32px; border-radius: 2px; }
.dial { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 32px; }
.dial-c { width: 28px; height: 28px; border-radius: 9999px; border: 2px solid #C9C4B6; color: #B4AE9E; display: flex; align-items: center; justify-content: center; font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700; font-size: 13px; transition: all .3s; }
.dial-c.cur { width: 36px; height: 36px; border-color: var(--gold); background: var(--navy); color: var(--gold); }
.dial-c.done { border-color: var(--gold); background: var(--gold); color: var(--navy); }
.dial-l { width: 20px; height: 2px; background: #D8D3C5; }
.dial-l.done { background: var(--gold); }
.step-lead { font-weight: 700; font-size: 15px; color: var(--navy); margin-bottom: 16px; line-height: 1.6; }
.q-lead { font-size: 12px; color: var(--inksoft); margin: -4px 0 8px; }
.field { margin-bottom: 20px; }
.field-label { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 12px; letter-spacing: 0.08em; color: var(--inksoft); margin-bottom: 8px; }
.field-hint { font-size: 10.5px; color: var(--inksoft); margin-top: 6px; }
.txt-input { width: 100%; padding: 10px 12px; border: 1.5px solid var(--line); background: #fff; font-size: 14px; color: var(--ink); outline: none; border-radius: 0; font-family: inherit; }
.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
.opt-card { display: block; width: 100%; text-align: left; padding: 16px 20px; border: 1.5px solid var(--line); background: #fff; border-radius: 2px; transition: all .15s; }
.opt-card.sel { border-color: var(--gold); background: var(--navy); color: var(--goldsoft); }
.opt-title { display: block; font-weight: 700; font-size: 15px; }
.opt-desc { display: block; margin-top: 4px; font-size: 12.5px; color: var(--inksoft); }
.opt-card.sel .opt-desc { color: var(--goldsoft); opacity: .85; }
.pills { display: flex; flex-wrap: wrap; gap: 6px; }
.pill { min-width: 40px; text-align: center; padding: 9px 0; border: 1px solid var(--line); background: #fff; color: var(--ink); font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700; font-size: 13px; border-radius: 2px; transition: all .15s; }
.pill.sel { background: var(--navy); color: var(--gold); border-color: var(--gold); }
.qblock { margin-bottom: 24px; }
.q-title { font-weight: 700; font-size: 14px; color: var(--navy); margin-bottom: 8px; }
.stack > * + * { margin-top: 8px; }
.navrow { display: flex; justify-content: space-between; align-items: center; margin-top: 32px; }
.back-btn { font-size: 13px; color: var(--inksoft); }
.btn-next { background: var(--navy); color: var(--gold); font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700; font-size: 13px; padding: 10px 24px; border-radius: 2px; }
.btn-next:disabled { background: #D8D3C5; color: #8B8676; cursor: default; }
.err { color: var(--alert); font-size: 12px; margin-top: 4px; }
.hero { background: var(--navy); border: 1px solid var(--gold); border-radius: 2px; padding: 24px; margin-bottom: 16px; }
.hero-eyebrow { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 10px; letter-spacing: 0.2em; color: var(--gold); }
.hero-title { font-family: 'Zen Maru Gothic', sans-serif; font-size: 20px; color: #fff; font-weight: 700; margin: 4px 0; }
.hero-sub { font-size: 11px; color: var(--goldsoft); margin-bottom: 16px; }
.hero-hr { height: 1px; background: var(--gold); opacity: .4; margin-bottom: 16px; }
.hero-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; text-align: center; }
.stat-n { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 22px; color: var(--gold); font-weight: 700; }
.stat-l { font-size: 10px; color: var(--goldsoft); }
.over-card { background: #F6E4E1; border: 1px solid var(--alert); padding: 16px; margin-bottom: 16px; }
.over-t { color: var(--alert); font-weight: 700; font-size: 13px; margin-bottom: 4px; }
.over-b { font-size: 12px; color: var(--navy); line-height: 1.7; }
.copy-btn { display: block; width: 100%; padding: 12px 0; background: var(--navy); color: var(--gold); font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700; font-size: 13px; border-radius: 2px; text-align: center; }
.copy-note { font-size: 10.5px; color: var(--inksoft); text-align: center; margin: 6px 0 16px; }
.pace-card { background: var(--goldsoft); border: 1px solid var(--gold); padding: 16px; margin-bottom: 16px; }
.pace-b { font-size: 12px; color: var(--navy); line-height: 1.7; }
.tabs { display: flex; border-bottom: 1px solid var(--line); margin-bottom: 20px; }
.tab { flex: 1; padding: 10px 0; text-align: center; font-weight: 700; font-size: 12px; color: var(--inksoft); border-bottom: 2px solid transparent; }
.tab.active { color: var(--navy); border-bottom-color: var(--gold); }
.sec-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.sec-title { font-weight: 700; font-size: 13px; color: var(--navy); }
.hint { font-size: 10.5px; color: var(--inksoft); }
.ex-card { border: 1px solid var(--line); background: #fff; }
.ex-card.open { border-color: var(--gold); }
.ex-head { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; text-align: left; }
.ex-left { display: flex; align-items: center; gap: 12px; }
.ex-num { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 11px; color: var(--gold); font-weight: 700; min-width: 18px; }
.ex-name { display: block; font-size: 13.5px; font-weight: 700; color: var(--ink); }
.ex-meta { display: block; font-size: 10.5px; color: var(--inksoft); }
.ex-arrow { font-size: 12px; color: var(--inksoft); transition: transform .2s; }
.ex-arrow.rot { transform: rotate(180deg); }
.ex-body { border-top: 1px solid #EFEBE0; padding: 12px 16px; }
.ex-lbl { font-size: 10px; font-weight: 700; color: var(--gold); letter-spacing: 0.05em; }
.ex-desc { font-size: 12px; line-height: 1.7; color: var(--ink); margin-top: 2px; }
.ex-reps { margin-top: 8px; font-size: 11.5px; font-weight: 700; color: var(--navy); }
.varbox { background: var(--paper); padding: 12px; }
.var-l { font-size: 10px; font-weight: 700; color: var(--inksoft); }
.var-t { font-size: 11.5px; color: var(--ink); margin-top: 2px; }
.strategy { background: var(--goldsoft); border: 1px solid var(--gold); padding: 20px; margin: 24px 0 32px; }
.str-t { font-weight: 700; font-size: 12.5px; color: var(--navy); margin-bottom: 4px; }
.str-b { font-size: 12.5px; color: var(--navy); line-height: 1.7; }
.pfc-cell { border: 1px solid var(--line); background: #fff; padding: 12px; text-align: center; }
.pfc-n { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 16px; font-weight: 700; color: var(--navy); }
.pfc-l { font-size: 10px; color: var(--inksoft); }
.days { display: flex; flex-wrap: wrap; gap: 6px; margin: 16px 0; }
.day-btn { padding: 6px 12px; border: 1px solid var(--line); background: #fff; color: var(--ink); font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 12px; font-weight: 700; border-radius: 2px; }
.day-btn.active { background: var(--navy); color: var(--gold); }
.tchip { min-width: 44px; text-align: center; line-height: 1.3; }
.tchip-s { display: block; font-size: 9px; font-weight: 700; opacity: .75; }
.swapsel { border-color: var(--gold); background: var(--goldsoft); color: var(--navy); box-shadow: 0 0 0 2px var(--gold) inset; }
.meal { margin-bottom: 16px; }
.meal-t { font-weight: 700; font-size: 12.5px; color: var(--navy); margin-bottom: 6px; }
.frow { margin-bottom: 8px; }
.food { display: flex; justify-content: space-between; align-items: center; padding: 8px 12px; background: #fff; border: 1px solid var(--line); }
.food-n { font-size: 12.5px; color: var(--ink); }
.food-g { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 12px; color: var(--gold); font-weight: 700; }
.subs { margin-top: 4px; padding-left: 12px; font-size: 10.5px; color: var(--inksoft); }
.veg { padding: 8px 12px; background: #fff; border: 1px solid var(--line); font-size: 12px; color: var(--inksoft); }
.total-card { background: #fff; border: 1px solid var(--gold); padding: 16px; margin: 16px 0; }
.total-t { font-weight: 700; font-size: 12.5px; color: var(--navy); margin-bottom: 4px; }
.total-b { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 12px; color: var(--inksoft); line-height: 1.7; }
.caution { background: var(--paper); border: 1px solid var(--line); padding: 16px; }
.caution-t { font-weight: 700; font-size: 12.5px; color: var(--navy); margin-bottom: 6px; }
.caution-i { font-size: 11.5px; line-height: 1.7; color: var(--ink); margin-bottom: 4px; }
.supcard { background: #fff; border: 1px solid var(--line); padding: 16px; }
.sup-n { font-weight: 700; font-size: 12.5px; color: var(--navy); }
.sup-note { font-size: 11.5px; color: var(--inksoft); margin-top: 2px; }
.bigcard { padding: 20px; margin-bottom: 16px; border: 1px solid var(--line); background: #fff; }
.bigcard.goldbg { background: var(--goldsoft); border-color: var(--gold); }
.bigcard.goldline { border-color: var(--gold); }
.big-t { font-weight: 700; font-size: 13px; color: var(--navy); margin-bottom: 4px; }
.big-b { font-size: 12.5px; color: var(--navy); line-height: 1.7; }
.big-type { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 15px; color: var(--gold); font-weight: 700; margin-bottom: 4px; }
.big-note { font-size: 12px; color: var(--inksoft); line-height: 1.6; }
.plat-step { background: #fff; border: 1px solid var(--line); padding: 16px; display: flex; gap: 12px; }
.plat-n { font-family: 'M PLUS Rounded 1c', sans-serif; font-size: 16px; color: var(--gold); font-weight: 700; min-width: 22px; }
.plat-t { font-weight: 700; font-size: 13px; color: var(--navy); }
.plat-b { font-size: 12px; color: var(--inksoft); line-height: 1.7; margin-top: 4px; }
.logic-card { border: 1px solid var(--line); background: #fff; margin-top: 24px; }
.logic-head { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; text-align: left; font-weight: 700; font-size: 12.5px; color: var(--navy); }
.logic-body { border-top: 1px solid #EFEBE0; padding: 12px 16px; }
.logic-i { font-size: 11.5px; line-height: 1.8; color: var(--ink); margin-bottom: 6px; }
.img-modal { position: fixed; inset: 0; background: rgba(60,52,46,.94); z-index: 50; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; }
.img-modal img { max-width: 100%; max-height: 60vh; border: 1px solid var(--gold); background: #1F9C8C; }
.img-modal-note { color: var(--goldsoft); font-size: 13px; line-height: 1.7; text-align: center; margin: 14px 0 4px; max-width: 32rem; }
.img-modal-sub { color: rgba(255,232,220,.7); font-size: 11px; text-align: center; margin-bottom: 14px; }
.img-modal-close { background: var(--gold); color: var(--navy); font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700; font-size: 13px; padding: 10px 28px; border-radius: 2px; }
.img-modal-dl { color: var(--goldsoft); font-size: 12px; text-decoration: underline; margin-top: 12px; display: inline-block; }
.reset-btn { display: block; width: 100%; padding: 12px 0; margin-top: 16px; border: 1.5px solid var(--navy); color: var(--navy); font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700; font-size: 13px; border-radius: 2px; background: transparent; text-align: center; }
.note { font-size: 10.5px; color: var(--inksoft); line-height: 1.6; }
.mb8 { margin-bottom: 8px; } .mb16 { margin-bottom: 16px; } .mt8 { margin-top: 8px; } .mt16 { margin-top: 16px; }
/* ---- v10 ポップ化オーバーライド ---- */
.opt-card, .bigcard, .hero, .pace-card, .over-card, .caution, .supcard, .plat-step, .logic-card, .strategy, .pfc-cell, .food, .veg, .total-card, .ex-card, .txt-input, .img-modal img { border-radius: 16px; }
.frow .subs { padding-left: 16px; }
.btn-primary, .btn-next, .copy-btn, .reset-btn, .pill, .day-btn, .img-modal-close { border-radius: 999px; }
.btn-primary, .btn-next:not(:disabled), .copy-btn { color: #FFFFFF; }
.pill.sel, .day-btn.active { color: #FFFFFF; }
.opt-card.sel { color: #FFFFFF; }
.dial-c.cur { color: #FFFFFF; }
.hero { background: linear-gradient(135deg, #23AC9A 0%, #1F9C8C 55%, #178578 100%); box-shadow: 0 8px 24px rgba(31,156,140,.25); }
.hero-title { color: #FFFFFF; }
.opt-card, .ex-card, .bigcard, .supcard, .plat-step { box-shadow: 0 2px 8px rgba(61,58,55,.05); }
.tab.active { border-bottom-width: 3px; }
.title { font-weight: 900; }
.brand-logo { display:block; height:34px; width:auto; margin:0 auto 12px; }
.trainer-badge { display:inline-block; margin-top:8px; font-family:'M PLUS Rounded 1c',sans-serif; font-size:10px; font-weight:700; letter-spacing:.1em; color:var(--gold); background:var(--goldsoft); padding:3px 12px; border-radius:999px; }
</style>
