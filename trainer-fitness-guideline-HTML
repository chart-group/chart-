        '<div class="note mt8">終了後: 使った部位を各30秒ストレッチ(柔軟性種目がある日はそれで代替OK)</div>' +
        (dm.rounds > 1 ? '<div class="note mt8">※ 01〜' + String(dm.menu.length).padStart(2, '0') + 'を' + dm.rounds + '周してから仕上げに進みます</div>' : '') +
        '<div class="bigcard goldline mt16"><div class="big-t">この日の消費目安: 約' + dayBurn + 'kcal</div>' +
        '<div class="big-note">種目ごとのMET値×時間×体重(' + d.weight + 'kg)で算出。週間スケジュール全体の消費 約' + r.selfWeekly + 'kcal+パーソナル分は、摂取カロリー' + r.targetCal + 'kcalの計算にすでに反映されています。</div></div>';
    }
    if ((d.injuries || []).length > 0) {
      html += '<div class="note mt8">※ ' + d.injuries.join('・') + 'に負担の大きい種目を自動で外しています。実施中に痛みが出た場合は中止し、担当トレーナー・医療機関にご相談ください。</div>';
    }
    html += '<div class="bigcard mt16"><div class="big-t">レベルアップのルール 💪</div>' +
      '<div class="big-note">全セットを余裕を持って完了できた種目は、2週間を目安に「回数+2(秒数種目は+10秒)」。それも余裕になったら各種目の「キツくするなら」へ進みます。少しずつ数字がちょっとずつ増えていくこと、それ自体がカラダの成長サインです。</div></div>';
    html += '<div class="strategy"><div class="str-t">継続戦略:' + STRATEGY[ptype].label + '</div><div class="str-b">' + STRATEGY[ptype].desc + '</div></div>';
  }

  if (state.resultTab === 'meals') {
    var dayData = wp.week[state.openDay];
    var dayDiff = dayData.totals.kcal - r.targetCal;
    html += '<div class="grid3 mb8">' +
      [["P", r.proteinG], ["F", r.fatG], ["C", r.carbG]].map(function (x) {
        return '<div class="pfc-cell"><div class="pfc-n">' + x[1] + 'g</div><div class="pfc-l">' + x[0] + ' 目標/日</div></div>';
      }).join('') + '</div>' +
      '<div class="note">※医療・栄養指導ではなく目安です。各日の合計が目標' + r.targetCal + 'kcalに着地するよう、P・脂質を先に確保し主食量で自動調整しています。</div>' +
      '<div class="days">' + wp.week.map(function (dd, i) {
        return '<button class="day-btn' + (state.openDay === i ? ' active' : '') + '" data-action="day" data-value="' + i + '">' + dd.day + '</button>';
      }).join('') + '</div>';

    var labels = ["朝食", "昼食", "夕食"];
    for (var si = 0; si < 3; si++) {
      var mm = dayData.meals[si];
      html += '<div class="meal"><div class="meal-t">' + labels[si] + '(約' + mm.kcal + 'kcal)</div>' +
        foodRowView(mm.mP, mm.pSubs) + foodRowView(mm.mC, mm.cSubs) +
        (mm.mF ? foodRowView(mm.mF, mm.fSubs) : '') +
        '<div class="veg">+ 野菜: ' + mm.veg + '(約120g)</div></div>';
    }

    html += '<div class="total-card"><div class="total-t">この日の合計(目安)</div><div class="total-b">' +
      'P ' + dayData.totals.p.toFixed(0) + 'g ・ F ' + dayData.totals.f.toFixed(0) + 'g ・ C ' + dayData.totals.c.toFixed(0) + 'g ・ 約' + dayData.totals.kcal + 'kcal<br>' +
      '目標 ' + r.targetCal + 'kcal との差: ' + (dayDiff >= 0 ? '+' : '') + dayDiff + 'kcal</div></div>' +
      '<div class="caution"><div class="caution-t">食事の注意点</div>' + MEAL_CAUTIONS.map(function (c) { return '<div class="caution-i">・' + c + '</div>'; }).join('') + '</div>' +
      '<button class="reset-btn" data-action="copyshop">1週間の買い物リストをコピー</button>' +
      '<div class="caution mt16"><div class="caution-t">コンビニ換算の目安(食材を用意できない日に)</div>' + CONV_LINES.map(function (c) { return '<div class="caution-i">・' + c + '</div>'; }).join('') + '</div>';
  }

  if (state.resultTab === 'supplement') {
    html += '<div class="bigcard' + (pc.needed ? ' goldbg' : ' goldline') + '"><div class="big-t">プロテインって必要?</div><div class="big-b">' + pc.msg + '</div></div>' +
      '<div class="bigcard"><div class="big-t">おすすめプロテイン種類</div><div class="big-type">' + pt.type + '</div><div class="big-note">' + pt.reason + '</div></div>' +
      '<div class="sec-title mb8">目的別サプリの一般的な選択肢</div>' +
      '<div class="stack mb16">' + sup.map(function (s) { return '<div class="supcard"><div class="sup-n">' + s.name + '</div><div class="sup-note">' + s.note + '</div></div>'; }).join('') + '</div>' +
      '<div class="note">※特定の医薬品的効能を示すものではなく一般的な情報です。持病・服薬中の方、妊娠中・産後の方は医師や管理栄養士にご相談ください。</div>';
  }

  if (state.resultTab === 'plateau') {
    html += '<div class="pace-card"><div class="pace-b">体重が<b>2週間以上</b>動かなくなったら、上から順に1つずつ試します。1ステップにつき約2週間、効果を確認してから次へ進むのがポイント。食事をがまんするのは、じつは最後の手段です。</div></div>' +
      '<div class="stack">' + PLATEAU_STEPS.map(function (s) {
        return '<div class="plat-step"><div class="plat-n">' + s.n + '</div><div><div class="plat-t">' + s.title + '</div><div class="plat-b">' + s.body + '</div></div></div>';
      }).join('') + '</div>' +
      '<div class="note mt16">※体調不良をともなう停滞や、強い疲労感が続くときは、ひとりで調整せず担当トレーナーや医療機関に相談してくださいね。</div>';
  }

  /* 計算根拠(折りたたみ) */
  html += '<div class="logic-card">' +
    '<button class="logic-head" data-action="logic"><span>この結果のしくみ(計算方法)</span><span class="ex-arrow' + (state.openLogic ? ' rot' : '') + '">▾</span></button>' +
    (state.openLogic ?
      '<div class="logic-body">' +
      '<div class="logic-i">① 基礎代謝: ' + r.bmrFormula + (r.lbm ? '(除脂肪体重 ' + r.lbm + 'kg)' : '') + ' → ' + r.bmr + 'kcal</div>' +
      '<div class="logic-i">② 日常活動: 基礎代謝 × ' + r.jobFactor + '(' + r.jobLabel + ')</div>' +
      '<div class="logic-i">③ 運動消費: 種目ごとのMET値 × 時間 × 体重で算出し週合計→日割り(+' + r.exDaily + 'kcal/日)。トレーニング時間・頻度・パーソナル回数を変えるとここが変わります</div>' +
      '<div class="logic-i">④ 総消費(TDEE): ②+③ = ' + r.tdee + 'kcal/日</div>' +
      '<div class="logic-i">⑤ 目標収支: 体重差 × 7,200kcal ÷ 日数。ただし1日−750kcal(またはTDEEの25%)を上限、基礎代謝を下限とする安全設計</div>' +
      '<div class="logic-i">⑥ PFC: P=体重×目的別係数(1.6〜2.2g) / F=総カロリーの25% / C=残り</div>' +
      '<div class="logic-i">⑦ 食事プラン: 各食でPと脂質を先に確保し、主食(C)の量でカロリーを目標に着地。だから日々の合計が摂取目安とほぼ一致します</div>' +
      '</div>' : '') +
    '</div>';

  html += '<button class="reset-btn" data-action="reset">もう一度診断する</button>';
  return html;
}

function render() {
  var inner = '<div class="header"><img class="brand-logo" src="data:image/png;base64," alt="CHART"><div class="eyebrow">BODY DIAGNOSTICS</div><h1 class="title">カラダづくり診断</h1><div class="trainer-badge">トレーナー用</div></div>';
  if (state.step >= 0 && state.step <= 3) inner += dialView();
  if (state.step === -1) inner += introView();
  if (state.step === 0) inner += step0View();
  if (state.step === 1) inner += step1View();
  if (state.step === 2) inner += step2View();
  if (state.step === 3) inner += step3View();
  if (state.step >= 0 && state.step <= 3) inner += navView();
  if (state.step === 4) inner += resultView();
  var modal = '';
  if (state.imgModal) {
    modal = '<div class="img-modal">' +
      '<img src="' + state.imgModal + '" alt="診断結果">' +
      '<div class="img-modal-note">画像を<b>長押し</b> →「<b>&quot;写真&quot;に追加</b>」(または「画像を保存」)を選ぶと写真フォルダに保存できます</div>' +
      '<div class="img-modal-sub">Androidの場合: 長押し →「画像をダウンロード」</div>' +
      '<button class="img-modal-close" data-action="imgclose">閉じる</button>' +
      '<a class="img-modal-dl" href="' + state.imgModal + '" download="CHART_診断結果.png">ファイルとして保存する場合はこちら</a>' +
      '</div>';
  }
  document.getElementById('root').innerHTML = '<div class="wrap">' + inner + '</div>' + modal;
}

/* ============ イベント ============ */
function handleNext() {
  if (state.step === 0) {
    var d = state.data;
    var nums = [d.age, d.height, d.weight, d.targetWeight];
    var bad = nums.some(function (v) { return !v || isNaN(parseFloat(v)) || parseFloat(v) <= 0; });
    if (bad) { state.err = '数値をすべて入力してください'; render(); return; }
    state.err = null;
  }
  if (!canProceed()) return;
  state.step++;
  if (state.step === 4) {
    state.resultTab = 'training'; state.openDay = 0; state.openEx = null; state.openLogic = false;
    state.schedTypes = null; state.swapMode = false; state.swapFirst = null;
    var ws0 = buildWeekSchedule(parseInt(state.data.freq, 10) || 1);
    state.openTDay = 0;
    for (var ti = 0; ti < ws0.sched.length; ti++) { if (ws0.sched[ti].type !== "rest") { state.openTDay = ti; break; } }
  }
  render();
}

document.addEventListener('click', function (e) {
  var t = e.target.closest('[data-action]');
  if (!t) return;
  var a = t.getAttribute('data-action');
  if (a === 'start') { state.step = 0; render(); }
  else if (a === 'back') { state.step--; render(); }
  else if (a === 'next') { handleNext(); }
  else if (a === 'set') { state.data[t.getAttribute('data-key')] = t.getAttribute('data-value'); render(); }
  else if (a === 'answer') { state.data.answers[parseInt(t.getAttribute('data-q'), 10)] = t.getAttribute('data-value'); render(); }
  else if (a === 'tab') { state.resultTab = t.getAttribute('data-value'); render(); }
  else if (a === 'day') { state.openDay = parseInt(t.getAttribute('data-value'), 10); render(); }
  else if (a === 'swapmode') { state.swapMode = !state.swapMode; state.swapFirst = null; render(); }
  else if (a === 'tday') {
    var tIdx = parseInt(t.getAttribute('data-value'), 10);
    if (state.swapMode) {
      if (state.swapFirst === null) state.swapFirst = tIdx;
      else if (state.swapFirst === tIdx) state.swapFirst = null;
      else { swapDays(state.swapFirst, tIdx); state.swapFirst = null; }
    } else { state.openTDay = tIdx; state.openEx = null; }
    render();
  }
  else if (a === 'ex') { var id = t.getAttribute('data-value'); state.openEx = state.openEx === id ? null : id; render(); }
  else if (a === 'logic') { state.openLogic = !state.openLogic; render(); }
  else if (a === 'adv') { state.openAdv = !state.openAdv; render(); }
  else if (a === 'mset') {
    var mk = t.getAttribute('data-key'), mv = t.getAttribute('data-value');
    state.data[mk] = state.data[mk] === mv ? "" : mv;
    if (mk === 'job' && state.data[mk] === "") state.data[mk] = "デスクワーク中心";
    render();
  }
  else if (a === 'mtog') {
    var gk = t.getAttribute('data-key'), gv = t.getAttribute('data-value');
    var arr = state.data[gk] || [];
    var gi = arr.indexOf(gv);
    if (gi === -1) arr.push(gv); else arr.splice(gi, 1);
    state.data[gk] = arr;
    render();
  }
  else if (a === 'copy') { copyResult(t); }
  else if (a === 'copyshop') { copyShopping(t); }
  else if (a === 'img') { saveImage(t); }
  else if (a === 'imgclose') { state.imgModal = null; render(); }
  else if (a === 'reset') {
    state.step = -1; state.resultTab = 'training'; state.openDay = 0; state.openTDay = 0; state.schedTypes = null; state.swapMode = false; state.swapFirst = null; state.openEx = null; state.openLogic = false; state.imgModal = null; state.err = null;
    state.data.goal = ''; state.data.equip = ''; state.data.time = ''; state.data.answers = [];
    render();
  }
});

document.addEventListener('input', function (e) {
  var k = e.target.getAttribute && e.target.getAttribute('data-key');
  if (k) state.data[k] = e.target.value;
});

render();
</script>
</body>
</html>
