    paceNote = "計算上の摂取カロリーが基礎代謝(" + bmr + "kcal)を下回るため、" + floorCal + "kcal/日を下限にしました。基礎代謝を下回る食事制限はリバウンドしやすく、体調も崩しやすいのでおすすめできません。このカロリーなら約" + realisticF + "ヶ月で届く見込み。足りない分は歩数や運動回数を増やしてカバーするのが安心です。";
  }

  var weeklyPace = ((tdee - targetCal) * 7) / KCAL_PER_KG;
  var proteinG;
  if (lbm !== null) {
    var lbmFactor = d.goal === "減量" ? 2.4 : d.goal === "筋肥大" ? 2.6 : d.goal === "産前産後ケア" ? 2.0 : 1.8;
    proteinG = Math.round(lbm * lbmFactor);
  } else {
    var proteinFactor = d.goal === "減量" ? 2.0 : d.goal === "筋肥大" ? 2.2 : d.goal === "産前産後ケア" ? 1.8 : 1.6;
    proteinG = Math.round(w * proteinFactor);
  }
  var fatG = Math.round((targetCal * 0.25) / 9);
  var carbG = Math.max(50, Math.round((targetCal - proteinG * 4 - fatG * 9) / 4));
  return {
    bmi: bmi.toFixed(1), bmr: bmr, tdee: tdee, exDaily: exDaily,
    selfWeekly: selfWeekly, avgSession: avgSession, persSession: persSession, weeklyBurn: weeklyBurn,
    targetCal: targetCal, proteinG: proteinG, fatG: fatG, carbG: carbG,
    weeklyPace: weeklyPace, overLimit: overLimit, overTitle: overTitle, paceNote: paceNote,
    totalSessions: homeF + pers, lbm: lbm, bmrFormula: bmrFormula, jobFactor: jobFactor, jobLabel: jobLabel
