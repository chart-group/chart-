}

/* --- 食事プラン: P・Fを先に確保し、Cの量で1食のカロリーを目標に着地させる --- */
function buildWeekPlan(targetP, targetF, targetC, targetCal, pList) {
  var PL = (pList && pList.length >= 3) ? pList : PROTEIN_SOURCES;
  var splits = [0.3, 0.4, 0.3];
  var week = DAYS.map(function (day, di) {
    var pIdx = [(di + 0) % PL.length, (di + 4) % PL.length, (di + 8) % PL.length];
    var cIdx = [(di + 0) % CARB_SOURCES.length, (di + 2) % CARB_SOURCES.length, (di + 4) % CARB_SOURCES.length];
    var meals = splits.map(function (split, si) {
      var kcalT = targetCal * split;
      var pT = targetP * split;
      var fT = targetF * split;

      var pFood = PL[pIdx[si]];
      var gP = clamp(Math.round((pT / pFood.p) * 100), 50, 350);
      if (pFood.f > 3) {
        var gPfat = Math.floor(((fT * 1.1 - VEG_MACROS.f) / pFood.f) * 100);
        gP = clamp(Math.min(gP, gPfat), 50, 350);
      }
      var mP = scaleFood(pFood, gP);

      var fFood = FAT_SOURCES[(di * 3 + si) % FAT_SOURCES.length];
      var fMax = Math.max(10, Math.round(35000 / kcalOf(fFood)));
      var fGap = fT - mP.f - VEG_MACROS.f;
      var gF = 0;
      if (fGap >= 2) gF = clamp(Math.round((fGap / fFood.f) * 100), 3, fMax);

      var kcalSoFar = mP.kcal + VEG_MACROS.kcal + (gF > 0 ? Math.round((kcalOf(fFood) * gF) / 100) : 0);
      var cFood = CARB_SOURCES[cIdx[si]];
      var cRemainKcal = Math.max(0, kcalT - kcalSoFar);
      var gC = clamp(Math.round((cRemainKcal / kcalOf(cFood)) * 100), 20, 400);
      var mC = scaleFood(cFood, gC);

      /* 主食が上限に達した場合、残差カロリーを脂質源に回して着地させる */
      var residual = Math.round(cRemainKcal - mC.kcal);
      if (residual > 30) gF = clamp(gF + Math.round((residual / kcalOf(fFood)) * 100), 3, fMax);
      var mF = gF > 0 ? scaleFood(fFood, gF) : null;

      var veg = VEG_OPTIONS[(di + si) % VEG_OPTIONS.length];
      var mealKcal = mP.kcal + mC.kcal + (mF ? mF.kcal : 0) + VEG_MACROS.kcal;
      return {
        mP: mP, mC: mC, mF: mF, veg: veg,
        pSubs: getSubs(PL, pFood), cSubs: getSubs(CARB_SOURCES, cFood),
        fSubs: mF ? getSubs(FAT_SOURCES, FAT_SOURCES[(di * 3 + si) % FAT_SOURCES.length]) : null,
        kcal: mealKcal
      };
    });
    var totals = meals.reduce(function (acc, mm) {
      return {
        p: acc.p + mm.mP.p + mm.mC.p + (mm.mF ? mm.mF.p : 0) + VEG_MACROS.p,
        f: acc.f + mm.mP.f + mm.mC.f + (mm.mF ? mm.mF.f : 0) + VEG_MACROS.f,
        c: acc.c + mm.mC.c + mm.mP.c + (mm.mF ? mm.mF.c : 0) + VEG_MACROS.c,
        kcal: acc.kcal + mm.kcal
      };
    }, { p: 0, f: 0, c: 0, kcal: 0 });
    return { day: day, meals: meals, totals: totals };
  });
  var avgProtein = week.reduce(function (s, dd) { return s + dd.totals.p; }, 0) / 7;
  var avgKcal = Math.round(week.reduce(function (s, dd) { return s + dd.totals.kcal; }, 0) / 7);
  return { week: week, avgProtein: avgProtein, avgKcal: avgKcal };
}

function proteinAssessment(targetP, avgProtein) {
  var gap = Math.round(targetP - avgProtein);
  if (gap <= targetP * 0.1) {
    return { needed: false, msg: "食事プランのみで目標たんぱく質量をほぼ達成できています。プロテインは必須ではありません。" };
  }
  var scoops = Math.ceil(gap / 24);
  return { needed: true, msg: "食事だけでは1日あたり約" + gap + "gのたんぱく質が不足します。プロテイン" + scoops + "杯(約" + scoops * 24 + "g)を補うことを推奨します。" };
}

function proteinTypeRecommend(goal) {
  if (goal === "減量") return { type: "WPI(ホエイアイソレート)", reason: "脂質・糖質が少なく、カロリーを抑えながらたんぱく質を摂取しやすいタイプです。" };
  if (goal === "筋肥大") return { type: "WPC(ホエイコンセントレート)", reason: "価格対たんぱく質量のバランスが良く、増量期に続けやすいタイプです。" };
  if (goal === "産前産後ケア") return { type: "—", reason: "産前産後は専門家(医師・管理栄養士)に相談の上で選択してください。" };
  return { type: "WPC または ソイプロテイン", reason: "日常的な補助として扱いやすいタイプです。乳製品が苦手な場合はソイ/ピープロテインを選択してください。" };
